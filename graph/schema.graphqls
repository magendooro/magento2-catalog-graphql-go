    websites: [Website]
    # PhysicalProductInterface
    weight: Float
    # CustomizableProductInterface
    options: [CustomizableOptionInterface]
    # RoutableInterface
    relative_url: String
    redirect_code: Int!
    type: UrlRewriteEntityTypeEnum
}

