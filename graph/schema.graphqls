# =============================================================================
# Configurable Product Types
# =============================================================================

type ConfigurableVariant {
    attributes: [ConfigurableAttributeOption]
    product: SimpleProduct
}

type ConfigurableAttributeOption {
    label: String
    code: String
    value_index: Int
    uid: ID!
}

type ConfigurableProductOptions {
    id: Int
    uid: ID!
    attribute_id: String
    attribute_id_v2: Int
    attribute_uid: ID!
    attribute_code: String
    label: String
    position: Int
    use_default: Boolean
    values: [ConfigurableProductOptionsValues]
    product_id: Int
}

type ConfigurableProductOptionsValues {
    value_index: Int
    uid: ID
    label: String
    default_label: String
    store_label: String
    use_default_value: Boolean
    swatch_data: SwatchDataInterface
}

type ConfigurableProductOptionsSelection {
    options_available_for_selection: [ConfigurableOptionAvailableForSelection!]
    configurable_options: [ConfigurableProductOption!]
    media_gallery: [MediaGalleryInterface!]
    variant: SimpleProduct
}

type ConfigurableOptionAvailableForSelection {
    option_value_uids: [ID!]!
    attribute_code: String!
}

type ConfigurableProductOption {
    uid: ID!
    attribute_code: String!
    label: String!
    values: [ConfigurableProductOptionValue!]
}

type ConfigurableProductOptionValue {
    uid: ID!
    is_available: Boolean!
    is_use_default: Boolean!
    label: String!
    swatch: SwatchDataInterface
}

# =============================================================================
# Grouped Product Types
# =============================================================================

type GroupedProductItem {
    qty: Float
    position: Int
    product: ProductInterface
}

# =============================================================================
# Bundle Product Types
# =============================================================================

type BundleItem {
    option_id: Int
    uid: ID!
    title: String
    required: Boolean
    type: String
    position: Int
    sku: String
    options: [BundleItemOption]
}

type BundleItemOption {
    id: Int
    uid: ID!
    label: String
    qty: Float
    quantity: Float
    position: Int
    is_default: Boolean
    price: Float
    price_type: PriceTypeEnum
    can_change_quantity: Boolean
    product: ProductInterface
}

enum PriceViewEnum {
    PRICE_RANGE
    AS_LOW_AS
}

enum ShipBundleItemsEnum {
    TOGETHER
    SEPARATELY
}

# =============================================================================
# Price Types
# =============================================================================

type PriceRange {
    minimum_price: ProductPrice!
    maximum_price: ProductPrice
}

type ProductPrice {
    regular_price: Money!
    final_price: Money!
    discount: ProductDiscount
    fixed_product_taxes: [FixedProductTax]
}

type ProductDiscount {
    percent_off: Float
    amount_off: Float
}

type Money {
    value: Float
    currency: CurrencyEnum
}

type FixedProductTax {
    amount: Money
    label: String
}

# Deprecated price types
type ProductPrices {
    minimalPrice: Price
    maximalPrice: Price
    regularPrice: Price
}

type Price {
    amount: Money
    adjustments: [PriceAdjustment]
}

type PriceAdjustment {
    amount: Money
    code: PriceAdjustmentCodesEnum
    description: PriceAdjustmentDescriptionEnum
}

enum PriceAdjustmentCodesEnum {
    TAX
    WEEE
    WEEE_TAX
}

enum PriceAdjustmentDescriptionEnum {
    INCLUDED
    EXCLUDED
}

enum PriceTypeEnum {
    FIXED
    PERCENT
    DYNAMIC
}

# =============================================================================
# Tier Prices
# =============================================================================

type TierPrice {
    final_price: Money
    quantity: Float
    discount: ProductDiscount
}

type ProductTierPrices {
    customer_group_id: String
    qty: Float
    value: Float
    percentage_value: Float
    website_id: Float
}

# =============================================================================
# Media Gallery
# =============================================================================

interface MediaGalleryInterface {
    url: String
    label: String
    position: Int
    disabled: Boolean
}

type ProductImage implements MediaGalleryInterface {
    url: String
    label: String
    position: Int
    disabled: Boolean
    types: [String]
}

type ProductVideo implements MediaGalleryInterface {
    url: String
    label: String
    position: Int
    disabled: Boolean
    video_content: ProductMediaGalleryEntriesVideoContent
}

type MediaGalleryEntry {
    id: Int
    uid: ID!
    media_type: String
    label: String
    position: Int
    disabled: Boolean
    types: [String]
    file: String
    content: ProductMediaGalleryEntriesContent
    video_content: ProductMediaGalleryEntriesVideoContent
}

type ProductMediaGalleryEntriesContent {
    base64_encoded_data: String
    type: String
    name: String
}

type ProductMediaGalleryEntriesVideoContent {
    media_type: String
    video_provider: String
    video_url: String
    video_title: String
    video_description: String
    video_metadata: String
}

# =============================================================================
# Product Links
# =============================================================================

type ProductLink {
    sku: String
    link_type: String
    linked_product_sku: String
    linked_product_type: String
    position: Int
}

# =============================================================================
# Category Filter / Result
# =============================================================================

input CategoryFilterInput {
    ids: FilterEqualTypeInput
    name: FilterMatchTypeInput
    parent_id: FilterEqualTypeInput
    url_key: FilterEqualTypeInput
    url_path: FilterEqualTypeInput
    category_uid: FilterEqualTypeInput
    parent_category_uid: FilterEqualTypeInput
}

type CategoryResult {
    items: [CategoryTree]
    page_info: SearchResultPageInfo
    total_count: Int
}

# =============================================================================
# Category Types
# =============================================================================

interface CategoryInterface {
    id: Int
    uid: ID!
    description: String
    name: String
    path: String
    path_in_store: String
    url_key: String
    url_path: String
    canonical_url: String
    position: Int
    level: Int
    created_at: String
    updated_at: String
    product_count: Int
    default_sort_by: String
    products(pageSize: Int = 20, currentPage: Int = 1, sort: ProductAttributeSortInput): CategoryProducts
    breadcrumbs: [Breadcrumb]
    url_suffix: String
}

type CategoryTree implements CategoryInterface & RoutableInterface {
    id: Int
    uid: ID!
    description: String
    name: String
    path: String
    path_in_store: String
    url_key: String
    url_path: String
    canonical_url: String
    position: Int
    level: Int
    created_at: String
    updated_at: String
    product_count: Int
    default_sort_by: String
    products(pageSize: Int = 20, currentPage: Int = 1, sort: ProductAttributeSortInput): CategoryProducts
    breadcrumbs: [Breadcrumb]
    url_suffix: String
    # RoutableInterface
    relative_url: String
    redirect_code: Int!
    type: UrlRewriteEntityTypeEnum
    children: [CategoryTree]
}

type Breadcrumb {
    category_id: Int
    category_uid: ID!
    category_name: String
    category_level: Int
    category_url_key: String
    category_url_path: String
}

type CategoryProducts {
    items: [ProductInterface]
    page_info: SearchResultPageInfo
    total_count: Int
}

# =============================================================================
# Reviews
# =============================================================================

type ProductReviews {
    items: [ProductReview]!
    page_info: SearchResultPageInfo!
}

type ProductReview {
    summary: String!
    text: String!
    nickname: String!
    created_at: String!
    average_rating: Float!
    ratings_breakdown: [ProductReviewRating!]!
}

type ProductReviewRating {
    name: String!
    value: String!
}

# =============================================================================
# Review mutations and metadata
# =============================================================================

input CreateProductReviewInput {
    sku: String!
    nickname: String!
    summary: String!
    text: String!
    ratings: [ProductReviewRatingInput!]!
}

input ProductReviewRatingInput {
    id: ID!
    value_id: ID!
}

type CreateProductReviewOutput {
    review: ProductReview!
}

type ProductReviewRatingsMetadata {
    items: [ProductReviewRatingMetadata!]!
}

type ProductReviewRatingMetadata {
    id: ID!
    name: String!
    values: [ProductReviewRatingValueMetadata!]!
}

type ProductReviewRatingValueMetadata {
    value: String!
    value_id: ID!
}

# =============================================================================
# Swatch Types
# =============================================================================

interface SwatchDataInterface {
    value: String
}

type ColorSwatchData implements SwatchDataInterface {
    value: String
}

type TextSwatchData implements SwatchDataInterface {
    value: String
}

type ImageSwatchData implements SwatchDataInterface {
    value: String
    thumbnail: String
}

# =============================================================================
# URL Rewrite
# =============================================================================

type UrlRewrite {
    url: String
    parameters: [HttpQueryParameter]
}

type HttpQueryParameter {
    name: String
    value: String
}

enum UrlRewriteEntityTypeEnum {
    PRODUCT
    CATEGORY
    CMS_PAGE
}

# =============================================================================
# Custom Attributes
# =============================================================================

type ProductCustomAttributes {
    items: [AttributeValueInterface!]!
    errors: [AttributeMetadataError!]!
}

interface AttributeValueInterface {
    code: ID!
}

type AttributeValue implements AttributeValueInterface {
    code: ID!
    value: String!
}

type AttributeSelectedOptions implements AttributeValueInterface {
    code: ID!
    selected_options: [AttributeSelectedOption!]!
}

type AttributeSelectedOption {
    label: String!
    value: String!
}

type AttributeMetadataError {
    type: AttributeMetadataErrorType!
    message: String!
}

enum AttributeMetadataErrorType {
    ENTITY_NOT_FOUND
    ATTRIBUTE_NOT_FOUND
    FILTER_NOT_FOUND
    UNDEFINED
}

input AttributeFilterInput {
    is_comparable: Boolean
    is_filterable: Boolean
    is_filterable_in_search: Boolean
    is_html_allowed_on_front: Boolean
    is_searchable: Boolean
    is_used_for_price_rules: Boolean
    is_used_for_promo_rules: Boolean
    is_visible_in_advanced_search: Boolean
    is_visible_on_front: Boolean
    is_wysiwyg_enabled: Boolean
    used_in_product_listing: Boolean
}

# =============================================================================
# Customizable Option Types
# =============================================================================

type CustomizableAreaOption implements CustomizableOptionInterface {
    title: String
    required: Boolean
    sort_order: Int
    uid: ID!
    value: CustomizableAreaValue
    product_sku: String
}

type CustomizableAreaValue {
    price: Float
    price_type: PriceTypeEnum
    sku: String
    max_characters: Int
    uid: ID!
}

type CustomizableDateOption implements CustomizableOptionInterface {
    title: String
    required: Boolean
    sort_order: Int
    uid: ID!
    value: CustomizableDateValue
    product_sku: String
}

type CustomizableDateValue {
    price: Float
    price_type: PriceTypeEnum
    type: CustomizableDateTypeEnum
    sku: String
    uid: ID!
}

enum CustomizableDateTypeEnum {
    DATE
    DATE_TIME
    TIME
}

type CustomizableDropDownOption implements CustomizableOptionInterface {
    title: String
    required: Boolean
    sort_order: Int
    uid: ID!
    value: [CustomizableDropDownValue]
}

type CustomizableDropDownValue {
    option_type_id: Int
    price: Float
    price_type: PriceTypeEnum
    sku: String
    title: String
    sort_order: Int
    uid: ID!
}

type CustomizableMultipleOption implements CustomizableOptionInterface {
    title: String
    required: Boolean
    sort_order: Int
    uid: ID!
    value: [CustomizableMultipleValue]
}

type CustomizableMultipleValue {
    option_type_id: Int
    price: Float
    price_type: PriceTypeEnum
    sku: String
    title: String
    sort_order: Int
    uid: ID!
}

type CustomizableFieldOption implements CustomizableOptionInterface {
    title: String
    required: Boolean
    sort_order: Int
    uid: ID!
    value: CustomizableFieldValue
    product_sku: String
}

type CustomizableFieldValue {
    price: Float
    price_type: PriceTypeEnum
    sku: String
    max_characters: Int
    uid: ID!
}

type CustomizableFileOption implements CustomizableOptionInterface {
    title: String
    required: Boolean
    sort_order: Int
    uid: ID!
    value: CustomizableFileValue
    product_sku: String
}

type CustomizableFileValue {
    price: Float
    price_type: PriceTypeEnum
    sku: String
    file_extension: String
    image_size_x: Int
    image_size_y: Int
    uid: ID!
}

type CustomizableRadioOption implements CustomizableOptionInterface {
    title: String
    required: Boolean
    sort_order: Int
    uid: ID!
    value: [CustomizableRadioValue]
}

type CustomizableRadioValue {
    option_type_id: Int
    price: Float
    price_type: PriceTypeEnum
    sku: String
    title: String
    sort_order: Int
    uid: ID!
}

type CustomizableCheckboxOption implements CustomizableOptionInterface {
    title: String
    required: Boolean
    sort_order: Int
    uid: ID!
    value: [CustomizableCheckboxValue]
}

type CustomizableCheckboxValue {
    option_type_id: Int
    price: Float
    price_type: PriceTypeEnum
    sku: String
    title: String
    sort_order: Int
    uid: ID!
}

