# =============================================================================
# Magento 2 Catalog GraphQL Schema - Go Implementation
# Compatible with Magento 2.4.x products() query
# =============================================================================

type Query {
    products(
        search: String
        filter: ProductAttributeFilterInput
        pageSize: Int = 20
        currentPage: Int = 1
        sort: ProductAttributeSortInput
    ): Products
    """Return a category tree, filtered by its IDs, url_key, url_path, or other attributes."""
    categories(
        filters: CategoryFilterInput
        pageSize: Int = 20
        currentPage: Int = 1
    ): CategoryResult
    """Deprecated: use categories instead."""
    categoryList(filters: CategoryFilterInput): [CategoryTree]
    """Deprecated: use categories instead."""
    category(id: Int): CategoryTree
    """Returns metadata for the active ratings that can be used in a product review."""
    productReviewRatingsMetadata: ProductReviewRatingsMetadata!
}

type Mutation {
    """Submit a new product review. Review is created with status pending (awaiting moderation)."""
    createProductReview(input: CreateProductReviewInput!): CreateProductReviewOutput!
}

# =============================================================================
# Products Response
# =============================================================================

type Products {
    items: [ProductInterface]
    page_info: SearchResultPageInfo
    total_count: Int
    aggregations(filter: AggregationsFilterInput): [Aggregation]
    sort_fields: SortFields
    suggestions: [SearchSuggestion]
}

type SearchResultPageInfo {
    page_size: Int
    current_page: Int
    total_pages: Int
}

# =============================================================================
# Aggregations
# =============================================================================

type Aggregation {
    count: Int
    label: String
    attribute_code: String!
    options: [AggregationOption]
    position: Int
}

type AggregationOption {
    count: Int
    label: String
    value: String!
    swatch_data: SwatchDataInterface
}

input AggregationsFilterInput {
    category: AggregationsCategoryFilterInput
}

input AggregationsCategoryFilterInput {
    includeDirectChildrenOnly: Boolean = false
}

# =============================================================================
# Sort
# =============================================================================

type SortFields {
    default: String
    options: [SortField]
}

type SortField {
    value: String
    label: String
}

type SearchSuggestion {
    search: String!
}

# =============================================================================
# Filter Inputs
# =============================================================================

input ProductAttributeFilterInput {
    category_id: FilterEqualTypeInput
    category_uid: FilterEqualTypeInput
    category_url_path: FilterEqualTypeInput
    url_key: FilterEqualTypeInput
    sku: FilterEqualTypeInput
    name: FilterMatchTypeInput
    price: FilterRangeTypeInput
    # EAV select/multiselect/boolean attributes (filterable in layered navigation)
    activity: FilterEqualTypeInput
    category_gear: FilterEqualTypeInput
    climate: FilterEqualTypeInput
    collar: FilterEqualTypeInput
    color: FilterEqualTypeInput
    eco_collection: FilterEqualTypeInput
    erin_recommends: FilterEqualTypeInput
    features_bags: FilterEqualTypeInput
    format: FilterEqualTypeInput
    gender: FilterEqualTypeInput
    manufacturer: FilterEqualTypeInput
    material: FilterEqualTypeInput
    new: FilterEqualTypeInput
    pattern: FilterEqualTypeInput
    performance_fabric: FilterEqualTypeInput
    sale: FilterEqualTypeInput
    size: FilterEqualTypeInput
    sleeve: FilterEqualTypeInput
    strap_bags: FilterEqualTypeInput
    style_bags: FilterEqualTypeInput
    style_bottom: FilterEqualTypeInput
    style_general: FilterEqualTypeInput
}

input FilterEqualTypeInput {
    in: [String]
    eq: String
}

input FilterRangeTypeInput {
    from: String
    to: String
}

input FilterMatchTypeInput {
    match: String
    match_type: FilterMatchTypeEnum
}

enum FilterMatchTypeEnum {
    FULL
    PARTIAL
}

# =============================================================================
# Sort Input
# =============================================================================

input ProductAttributeSortInput {
    relevance: SortEnum
    position: SortEnum
    name: SortEnum
    price: SortEnum
}

enum SortEnum {
    ASC
    DESC
}

# =============================================================================
# ProductInterface
# =============================================================================

interface ProductInterface {
    # Core fields
    id: Int
    uid: ID!
    name: String
    sku: String
    type_id: String
    attribute_set_id: Int
    description: ComplexTextValue
    short_description: ComplexTextValue
    special_price: Float
    special_from_date: String
    special_to_date: String
    meta_title: String
    meta_keyword: String
    meta_description: String
    new_from_date: String
    new_to_date: String
    tier_price: Float
    options_container: String
    created_at: String
    updated_at: String
    country_of_manufacture: String
    manufacturer: Int
    gift_message_available: Boolean
    is_personalizable: Boolean
    is_virtual: Boolean
    canonical_url: String

    # Images
    image: ProductImage
    small_image: ProductImage
    thumbnail: ProductImage
    swatch_image: String
    media_gallery: [MediaGalleryInterface]
    media_gallery_entries: [MediaGalleryEntry]

    # Prices
    price_range: PriceRange!
    price: ProductPrices
    price_tiers: [TierPrice]
    tier_prices: [ProductTierPrices]

    # Categories
    categories: [CategoryInterface]

    # Inventory
    stock_status: ProductStockStatus
    only_x_left_in_stock: Float
    quantity: Float
    min_sale_qty: Float
    max_sale_qty: Float

    # URLs
    url_key: String
    url_suffix: String
    url_path: String
    url_rewrites: [UrlRewrite]

    # Related products
    related_products: [ProductInterface]
    upsell_products: [ProductInterface]
    crosssell_products: [ProductInterface]
    product_links: [ProductLink]

    # Reviews
    rating_summary: Float!
    review_count: Int!
    reviews(pageSize: Int = 20, currentPage: Int = 1): ProductReviews!

    # Custom attributes
    custom_attributesV2(filters: AttributeFilterInput): ProductCustomAttributes

    # Deprecated
    websites: [Website]
}

# =============================================================================
# Physical Product Interface
# =============================================================================

interface PhysicalProductInterface {
    weight: Float
}

# =============================================================================
# Customizable Product Interface
# =============================================================================

interface CustomizableProductInterface {
    options: [CustomizableOptionInterface]
}

interface CustomizableOptionInterface {
    title: String
    required: Boolean
    sort_order: Int
    uid: ID!
}

# =============================================================================
# Routable Interface
# =============================================================================

interface RoutableInterface {
    relative_url: String
    redirect_code: Int!
    type: UrlRewriteEntityTypeEnum
}

# =============================================================================
# Product Types
# =============================================================================

